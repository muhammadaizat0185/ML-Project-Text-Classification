# Ignore raw and cleaned datasets (they are >100MB and will block GitHub pushes)
*.csv

# Ignore large preprocessed sparse feature matrices and labels
processed_data/

# Ignore local trained models and vectorizers
models/

# Ignore python compile caches
__pycache__/
*.pyc

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore Word document intermediate backups
Full Report_backup.docx
Full Report_final.docx
Full Report_updated.docx

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore virtual environments
venv/
.venv/
env/

# Ignore local IDE settings
.vscode/
.idea/

# Ignore compressed archives
*.rar
*.zip
*.7z
*.tar.gz
